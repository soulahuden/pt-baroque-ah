<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>
    <title>Komentar — PT. Baroque-ah</title>
</head>
<body class="text-black min-h-screen flex flex-col relative overflow-x-hidden hero-gradient">

    <img src="/img/bg.png" alt="" class="bg-img" onerror="this.style.display='none'">
    <div class="hero-overlay"></div>

    <%- include('partials/nav', { current: 'comments' }) %>

    <main class="relative z-20 flex-grow px-8 py-8 max-w-3xl mx-auto w-full">

        <div class="mb-6">
            <h2 class="text-3xl font-bold tracking-tight">Komentar</h2>
            <p class="text-gray-500 text-sm mt-1">Target: Stored XSS — komentar di-render tanpa escaping</p>
        </div>

        <div class="bg-white/70 backdrop-blur-md border border-gray-200 rounded-3xl shadow-xl p-6 mb-6">
            <% if (posted) { %>
            <div class="bg-green-50 border border-green-200 rounded-xl px-4 py-2 mb-4 text-sm text-green-700">
                Komentar dikirim!
                <% if (!session.nickname) { %>
                <a href="/" class="underline">Set nickname</a> dulu supaya namamu muncul.
                <% } %>
            </div>
            <% } %>

            <form action="/comments" method="POST" class="flex flex-col gap-4">
                <div>
                    <label class="block text-xs font-semibold text-gray-600 mb-1.5 ml-1">
                        Komentar
                        <span class="font-normal text-gray-400">(coba: &lt;script&gt;alert('XSS')&lt;/script&gt;)</span>
                    </label>
                    <textarea name="body" rows="3" placeholder="Tulis komentar... atau payload XSS :)"
                        class="w-full bg-white/80 border border-gray-200 rounded-2xl px-5 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-black/20 resize-none"></textarea>
                </div>
                <button type="submit"
                    class="bg-black text-white rounded-full py-3 text-sm font-semibold hover:bg-gray-800 transition shadow-md self-end px-8">
                    Kirim Komentar
                </button>
            </form>

            <p class="text-[10px] text-gray-400 mt-3 font-mono">
                Hint XSS: &lt;script&gt;alert(document.cookie)&lt;/script&gt;
                &nbsp;|&nbsp; &lt;img src=x onerror=alert(1)&gt;
            </p>
        </div>

        <div class="flex flex-col gap-3">
            <% if (comments.length === 0) { %>
            <div class="bg-white/50 border border-gray-100 rounded-2xl px-6 py-4 text-sm text-gray-400 text-center">
                Belum ada komentar.
            </div>
            <% } %>

            <% comments.forEach(function(c) { %>
            <div class="bg-white/65 backdrop-blur-md border border-gray-200 rounded-2xl px-5 py-4 shadow-sm">
                <div class="flex items-center justify-between mb-2">
                    <span class="text-xs font-semibold text-gray-700"><%= c.nickname %></span>
                    <span class="text-[10px] text-gray-400"><%= new Date(c.created_at).toLocaleString('id-ID') %></span>
                </div>
                <div class="text-sm text-gray-800"><%- c.body %></div>
            </div>
            <% }); %>
        </div>

        <div class="mt-8 pt-4 border-t border-gray-100/50 text-center">
            <span style="color: transparent; font-size: 10px; user-select: none;">
                <a href="/admin-backup" style="color: inherit; text-decoration: none;">admin panel</a>
            </span>
        </div>

    </main>

</body>
</html>
