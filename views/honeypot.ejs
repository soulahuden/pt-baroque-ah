<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%
    // Judul berbeda per route supaya lebih meyakinkan
    const isBackup = route && route.includes('backup');
    const pageTitle = isBackup ? 'Admin Backup Portal' : 'Internal Login';
    const systemName = isBackup ? 'Backup & Recovery Console' : 'PT. Baroque-ah Internal Portal';
    %>
    <title><%= pageTitle %> — PT. Baroque-ah</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .mono { font-family: 'JetBrains Mono', monospace; }
        .hero-gradient {
            background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #1a0a2e 100%);
        }
    </style>
</head>

<%
// Timestamp palsu yang terlihat realistis
const fakeLastLogin = new Date(Date.now() - Math.floor(Math.random() * 7200000 + 3600000));
const fakeLastLoginStr = fakeLastLogin.toLocaleString('en-GB', {
    day:'2-digit', month:'short', year:'numeric',
    hour:'2-digit', minute:'2-digit', timeZoneName:'short'
});
const fakeSessionToken = Math.random().toString(36).substring(2,10).toUpperCase();
const fakeBuildVer = '2.' + (Math.floor(Math.random()*3)+4) + '.' + Math.floor(Math.random()*20);
%>

<body class="text-white min-h-screen flex flex-col hero-gradient">

    <!-- Top bar — terlihat seperti internal system -->
    <div class="w-full bg-black/40 border-b border-white/5 px-8 py-2 flex items-center justify-between text-xs mono text-gray-500">
        <span>PT. BAROQUE-AH INTRANET &mdash; RESTRICTED ACCESS</span>
        <span class="flex items-center gap-4">
            <span>Session: <span class="text-gray-400"><%= fakeSessionToken %></span></span>
            <span>v<%= fakeBuildVer %></span>
            <span class="flex items-center gap-1">
                <span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block"></span> SYS OK
            </span>
        </span>
    </div>

    <main class="flex-grow flex items-center justify-center px-8 py-12">
        <div class="w-full max-w-md">

            <!-- Header -->
            <div class="text-center mb-8">
                <div class="w-16 h-16 bg-indigo-500/20 border border-indigo-500/40 rounded-2xl flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round"
                            d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.955 11.955 0 003 10c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.57-.598-3.75h-.152c-3.196 0-6.1-1.249-8.25-3.286z" />
                    </svg>
                </div>
                <h1 class="text-2xl font-bold text-white"><%= systemName %></h1>
                <p class="text-gray-400 text-sm mt-1">Authorized personnel only &mdash; All access is logged</p>
            </div>

            <!-- Login card -->
            <div class="bg-white/[0.06] backdrop-blur-xl border border-white/10 rounded-3xl p-8 shadow-2xl">

                <!-- Auth failed banner -->
                <% if (loginFailed) { %>
                <div class="bg-red-950/60 border border-red-700/50 rounded-xl px-4 py-3 mb-6 flex items-start gap-3">
                    <svg class="w-5 h-5 text-red-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                    </svg>
                    <div>
                        <p class="text-sm font-semibold text-red-300">Authentication Failed</p>
                        <p class="text-xs text-red-400 mt-0.5">Invalid credentials. This attempt has been logged.</p>
                    </div>
                </div>
                <% } %>

                <form action="<%= route %>" method="POST" class="flex flex-col gap-5" autocomplete="off">

                    <div>
                        <label class="block text-xs font-semibold text-gray-400 mb-1.5 tracking-wide uppercase">
                            Username / Employee ID
                        </label>
                        <input type="text" name="username"
                            value="<%= username %>"
                            placeholder="e.g. admin, sysadmin, root"
                            autocomplete="off"
                            class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-gray-600 focus:outline-none focus:border-indigo-500/60 focus:ring-1 focus:ring-indigo-500/30 transition mono">
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-gray-400 mb-1.5 tracking-wide uppercase">
                            Password
                        </label>
                        <input type="password" name="password"
                            placeholder="••••••••"
                            autocomplete="new-password"
                            class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-gray-600 focus:outline-none focus:border-indigo-500/60 focus:ring-1 focus:ring-indigo-500/30 transition">
                    </div>

                    <button type="submit"
                        class="w-full bg-indigo-600 hover:bg-indigo-500 text-white py-3 rounded-xl text-sm font-semibold transition shadow-lg shadow-indigo-900/30 mt-1">
                        Sign In to <%= isBackup ? 'Backup Console' : 'Admin Portal' %>
                    </button>

                </form>

                <!-- Footer info — terlihat seperti system info asli -->
                <div class="mt-6 pt-5 border-t border-white/5 space-y-1.5">
                    <div class="flex justify-between text-[11px]">
                        <span class="text-gray-600">Last failed login</span>
                        <span class="text-gray-500 mono"><%= fakeLastLoginStr %></span>
                    </div>
                    <div class="flex justify-between text-[11px]">
                        <span class="text-gray-600">Session timeout</span>
                        <span class="text-gray-500">30 minutes</span>
                    </div>
                    <div class="flex justify-between text-[11px]">
                        <span class="text-gray-600">Support</span>
                        <span class="text-gray-500">helpdesk@baroque-ah.internal</span>
                    </div>
                </div>
            </div>

            <!-- System status bar -->
            <div class="mt-4 bg-black/30 border border-white/5 rounded-xl px-4 py-2 flex items-center justify-between text-[10px] mono text-gray-600">
                <span>SERVER: prod-admin-01 &middot; DC: JKT-1</span>
                <span>TLS 1.3 &middot; AES-256</span>
            </div>

        </div>
    </main>

    <!-- Bottom bar -->
    <div class="w-full bg-black/40 border-t border-white/5 px-8 py-2 text-center text-[10px] mono text-gray-700">
        &copy; 2024 PT. Baroque-ah IT Department &mdash; Unauthorized access is prohibited and will be prosecuted.
    </div>

</body>
</html>
