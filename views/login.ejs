<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>
    <title>Login — PT. Baroque-ah</title>
</head>
<body class="text-black min-h-screen flex flex-col relative overflow-hidden hero-gradient">

    <img src="/img/bg.png" alt="" class="bg-img" onerror="this.style.display='none'">
    <div class="hero-overlay"></div>

    <%- include('partials/nav', { current: 'login' }) %>

    <main class="relative z-20 flex-grow flex items-center justify-center px-8 py-12">
        <div class="w-full max-w-md">

            <!-- Card utama -->
            <div class="bg-white/70 backdrop-blur-md rounded-3xl border border-gray-200 shadow-xl p-8">

                <div class="mb-6">
                    <h2 class="text-3xl font-bold tracking-tight">Login</h2>
                    <p class="text-gray-500 text-sm mt-1">Target: autentikasi rentan SQLi</p>
                </div>

                <!-- Hasil login -->
                <% if (user) { %>
                <div class="bg-green-50 border border-green-300 rounded-2xl px-4 py-4 mb-5 text-sm">
                    <p class="font-bold text-green-800 mb-1">Login berhasil!</p>
                    <p class="text-green-700">Selamat datang, <strong><%= user.username %></strong> (role: <%= user.role %>)</p>
                    <% if (user.secret_flag) { %>
                    <div class="mt-3 bg-white/80 rounded-xl px-3 py-2 font-mono text-xs text-green-900 border border-green-200">
                        FLAG: <strong><%= user.secret_flag %></strong>
                    </div>
                    <% } %>
                </div>
                <% } %>

                <!-- Error -->
                <% if (error) { %>
                <div class="bg-red-50 border border-red-200 rounded-2xl px-4 py-3 mb-5 text-sm text-red-700">
                    <%= error %>
                </div>
                <% } %>

                <!-- Form login -->
                <form action="/login" method="POST" class="flex flex-col gap-4">
                    <div>
                        <label class="block text-xs font-semibold text-gray-600 mb-1.5 ml-1">Username</label>
                        <input type="text" name="username" placeholder="admin"
                            class="w-full bg-white/80 border border-gray-200 rounded-full px-5 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-black/20">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-600 mb-1.5 ml-1">Password</label>
                        <input type="text" name="password" placeholder="password123"
                            class="w-full bg-white/80 border border-gray-200 rounded-full px-5 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-black/20">
                    </div>
                    <button type="submit"
                        class="bg-black text-white rounded-full py-3 text-sm font-semibold hover:bg-gray-800 transition mt-1 shadow-md">
                        Masuk
                    </button>
                </form>
            </div>

            <!-- Raw query card — edukasi SQLi -->
            <% if (rawQuery) { %>
            <div class="mt-4 bg-white/50 backdrop-blur-sm border border-gray-200 rounded-2xl p-4 shadow-sm">
                <p class="text-xs font-semibold text-gray-500 mb-2">Query yang dieksekusi ke database:</p>
                <pre class="text-xs font-mono text-gray-800 whitespace-pre-wrap break-all bg-white/60 rounded-xl px-3 py-2 border border-gray-100"><%= rawQuery %></pre>
                <p class="text-[10px] text-gray-400 mt-2">
                    Coba isi username dengan: <code class="font-mono bg-gray-100 px-1 rounded">' OR '1'='1' --</code>
                </p>
            </div>
            <% } else { %>
            <div class="mt-4 bg-white/50 backdrop-blur-sm border border-gray-200 rounded-2xl p-4 shadow-sm">
                <p class="text-xs font-semibold text-gray-500 mb-1">Hint SQL Injection:</p>
                <p class="text-xs text-gray-600">Username: <code class="font-mono bg-gray-100 px-1 py-0.5 rounded">' OR '1'='1' --</code></p>
                <p class="text-xs text-gray-600 mt-1">Password: <em>(biarkan kosong atau isi bebas)</em></p>
            </div>
            <% } %>

        </div>
    </main>

</body>
</html>
