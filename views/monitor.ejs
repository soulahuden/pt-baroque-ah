<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PT. Baroque-ah — Live Security Monitor</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background: #030712; }
        .mono { font-family: 'JetBrains Mono', monospace; }

        /* Slide-in animasi untuk event baru */
        @keyframes slide-in {
            from { opacity: 0; transform: translateY(-18px) scale(0.98); }
            to   { opacity: 1; transform: translateY(0)     scale(1); }
        }
        .event-new { animation: slide-in 0.35s cubic-bezier(0.34,1.56,0.64,1) forwards; }

        /* Pulse untuk honeypot */
        @keyframes hpulse {
            0%,100% { box-shadow: 0 0 0 0 rgba(239,68,68,0.3); }
            50%      { box-shadow: 0 0 16px 6px rgba(239,68,68,0); }
        }
        .honeypot-glow { animation: hpulse 2s ease-in-out infinite; }

        /* Feed container: scroll otomatis */
        #feed { overflow-y: auto; max-height: calc(100vh - 140px); scroll-behavior: smooth; }
        #leaderboard-wrap { overflow-y: auto; max-height: calc(100vh - 140px); }

        /* Scrollbar dark */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #111; }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 3px; }

        /* Layer badge colors */
        .badge-waf      { background: #f97316; color: #fff; }
        .badge-honeypot { background: #ef4444; color: #fff; }
        .badge-suricata { background: #06b6d4; color: #fff; }
        .badge-unknown  { background: #6b7280; color: #fff; }

        /* Card border per layer */
        .card-waf      { border-color: rgba(249,115,22,0.35); }
        .card-honeypot { border-color: rgba(239,68,68,0.5); }
        .card-suricata { border-color: rgba(6,182,212,0.35); }
        .card-unknown  { border-color: rgba(107,114,128,0.25); }

        /* Text per layer */
        .text-waf      { color: #fb923c; }
        .text-honeypot { color: #f87171; }
        .text-suricata { color: #22d3ee; }

        /* Rank medal colors */
        .rank-1 { color: #fbbf24; }
        .rank-2 { color: #9ca3af; }
        .rank-3 { color: #cd7c4a; }
    </style>
</head>

<body class="text-white min-h-screen flex flex-col select-none">

<!-- ─── HEADER BAR ─────────────────────────────────────────────────────────── -->
<header class="flex-none bg-gray-950/80 backdrop-blur border-b border-white/5 px-6 py-3 flex items-center gap-6">

    <!-- Logo + title -->
    <div class="flex items-center gap-3 shrink-0">
        <div class="w-8 h-8 rounded-full border-2 border-orange-500 flex items-center justify-center">
            <div class="w-3 h-3 bg-orange-500 rotate-45"></div>
        </div>
        <div>
            <p class="text-xs text-gray-500 font-semibold tracking-widest uppercase">PT. Baroque-ah</p>
            <p class="text-base font-bold leading-none text-white">Live Security Monitor</p>
        </div>
    </div>

    <!-- Stat pills -->
    <div class="flex items-center gap-3 flex-wrap flex-1">
        <!-- Total -->
        <div class="bg-white/5 border border-white/10 rounded-full px-4 py-1.5 flex items-center gap-2">
            <span class="text-xs text-gray-400 font-semibold">TOTAL</span>
            <span id="stat-total" class="text-lg font-black text-white"><%= stats.total || 0 %></span>
        </div>
        <!-- Peserta unik -->
        <div class="bg-white/5 border border-white/10 rounded-full px-4 py-1.5 flex items-center gap-2">
            <span class="text-xs text-gray-400 font-semibold">PESERTA</span>
            <span id="stat-users" class="text-lg font-black text-white"><%= stats.unique_users || 0 %></span>
        </div>
        <!-- Breakdown per tipe -->
        <div class="flex items-center gap-2">
            <div class="bg-orange-950/60 border border-orange-700/30 rounded-full px-3 py-1 flex items-center gap-1.5">
                <span class="text-[10px] text-orange-400 font-bold">SQLi</span>
                <span id="stat-sqli" class="text-sm font-black text-orange-300"><%= stats.sqli || 0 %></span>
            </div>
            <div class="bg-purple-950/60 border border-purple-700/30 rounded-full px-3 py-1 flex items-center gap-1.5">
                <span class="text-[10px] text-purple-400 font-bold">XSS</span>
                <span id="stat-xss" class="text-sm font-black text-purple-300"><%= stats.xss || 0 %></span>
            </div>
            <div class="bg-yellow-950/60 border border-yellow-700/30 rounded-full px-3 py-1 flex items-center gap-1.5">
                <span class="text-[10px] text-yellow-400 font-bold">PATH</span>
                <span id="stat-path" class="text-sm font-black text-yellow-300"><%= stats.path_traversal || 0 %></span>
            </div>
            <div class="bg-green-950/60 border border-green-700/30 rounded-full px-3 py-1 flex items-center gap-1.5">
                <span class="text-[10px] text-green-400 font-bold">CMD</span>
                <span id="stat-cmd" class="text-sm font-black text-green-300"><%= stats.command_injection || 0 %></span>
            </div>
            <div class="bg-red-950/60 border border-red-700/30 rounded-full px-3 py-1 flex items-center gap-1.5">
                <span class="text-[10px] text-red-400 font-bold">HONEY</span>
                <span id="stat-honey" class="text-sm font-black text-red-300"><%= stats.honeypot || 0 %></span>
            </div>
            <div class="bg-cyan-950/60 border border-cyan-700/30 rounded-full px-3 py-1 flex items-center gap-1.5">
                <span class="text-[10px] text-cyan-400 font-bold">SURICATA</span>
                <span id="stat-suricata" class="text-sm font-black text-cyan-300"><%= stats.suricata || 0 %></span>
            </div>
        </div>
    </div>

    <!-- Live indicator -->
    <div class="flex items-center gap-2 shrink-0">
        <span class="relative flex h-3 w-3">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-3 w-3 bg-red-500"></span>
        </span>
        <span class="text-xs text-gray-400 font-semibold">LIVE</span>
        <!-- Legend -->
        <div class="hidden lg:flex items-center gap-3 ml-4 border-l border-white/10 pl-4">
            <span class="flex items-center gap-1 text-xs"><span class="w-2 h-2 rounded-full bg-orange-500 inline-block"></span><span class="text-gray-400">App WAF</span></span>
            <span class="flex items-center gap-1 text-xs"><span class="w-2 h-2 rounded-full bg-red-500 inline-block"></span><span class="text-gray-400">Honeypot</span></span>
            <span class="flex items-center gap-1 text-xs"><span class="w-2 h-2 rounded-full bg-cyan-400 inline-block"></span><span class="text-gray-400">Suricata</span></span>
        </div>

        <!-- Tombol Reset — hanya muncul di monitor (URL sudah punya token) -->
        <button id="btn-reset"
            onclick="confirmReset()"
            class="ml-4 flex items-center gap-1.5 bg-red-950/60 hover:bg-red-900/70 border border-red-800/50 text-red-400 hover:text-red-300 px-3 py-1.5 rounded-full text-xs font-bold transition">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
            </svg>
            Reset
        </button>
    </div>
</header>

<!-- Modal konfirmasi reset -->
<div id="reset-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/70 backdrop-blur-sm">
    <div class="bg-gray-900 border border-red-800/50 rounded-3xl p-8 max-w-sm w-full mx-4 shadow-2xl text-center">
        <div class="w-14 h-14 bg-red-950/60 border border-red-700/40 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
        </div>
        <h3 class="text-lg font-bold text-white mb-2">Reset semua data?</h3>
        <p class="text-sm text-gray-400 mb-6 leading-relaxed">
            Semua <strong class="text-white">events</strong>, <strong class="text-white">komentar</strong> (termasuk XSS payloads), dan <strong class="text-white">leaderboard</strong> akan dihapus permanen.<br>
            <span class="text-gray-500 text-xs">Semua tab monitor akan ikut reset serentak.</span>
        </p>
        <div class="flex gap-3">
            <button onclick="closeResetModal()"
                class="flex-1 bg-white/5 hover:bg-white/10 border border-white/10 text-gray-300 py-2.5 rounded-xl text-sm font-semibold transition">
                Batal
            </button>
            <button onclick="doReset()"
                class="flex-1 bg-red-600 hover:bg-red-500 text-white py-2.5 rounded-xl text-sm font-bold transition">
                Ya, Reset
            </button>
        </div>
    </div>
</div>

<!-- ─── MAIN: FEED + LEADERBOARD ──────────────────────────────────────────── -->
<div class="flex-1 flex gap-0 overflow-hidden">

    <!-- LIVE FEED (kiri, 65%) -->
    <section class="flex-1 flex flex-col border-r border-white/5">
        <div class="px-4 py-2 flex items-center justify-between border-b border-white/5">
            <h2 class="text-xs font-bold tracking-widest uppercase text-gray-500">Live Event Feed</h2>
            <span id="feed-count" class="text-xs text-gray-600">0 events</span>
        </div>

        <div id="feed" class="flex-1 px-4 py-3 flex flex-col gap-3">
            <!-- Events diisi oleh JS di bawah -->
            <% if (!events || events.length === 0) { %>
            <div class="text-center text-gray-700 text-sm mt-16">
                <p class="text-4xl mb-3">🛡</p>
                <p>Menunggu serangan pertama…</p>
                <p class="text-xs mt-1">Minta peserta buka <span class="mono text-gray-500">/play</span> dan mulai</p>
            </div>
            <% } %>
        </div>
    </section>

    <!-- LEADERBOARD (kanan, 35%) -->
    <section class="w-80 xl:w-96 flex flex-col bg-gray-950/40">
        <div class="px-5 py-2 border-b border-white/5 flex items-center justify-between">
            <h2 class="text-xs font-bold tracking-widest uppercase text-gray-500">Leaderboard</h2>
            <span class="text-xs text-gray-600">by total attacks</span>
        </div>

        <div id="leaderboard-wrap" class="flex-1 px-4 py-3">
            <div id="leaderboard-body" class="flex flex-col gap-2">
                <!-- Diisi oleh JS -->
            </div>
        </div>
    </section>
</div>

<!-- ─── SCRIPT ────────────────────────────────────────────────────────────── -->
<script src="/socket.io/socket.io.js"></script>
<script>
// ── Data awal dari server ────────────────────────────────────────────────────
const INIT_EVENTS      = <%- eventsJson %>;
const INIT_LEADERBOARD = <%- leaderboardJson %>;
const INIT_STATS       = <%- statsJson %>;

// ── State ────────────────────────────────────────────────────────────────────
let statState = {
    total:            parseInt(INIT_STATS.total)            || 0,
    unique_users:     parseInt(INIT_STATS.unique_users)     || 0,
    sqli:             parseInt(INIT_STATS.sqli)             || 0,
    xss:              parseInt(INIT_STATS.xss)              || 0,
    path_traversal:   parseInt(INIT_STATS.path_traversal)   || 0,
    command_injection:parseInt(INIT_STATS.command_injection) || 0,
    honeypot:         parseInt(INIT_STATS.honeypot)         || 0,
    suricata:         parseInt(INIT_STATS.suricata)         || 0,
};

// Leaderboard state: { nickname → { total, sqli, xss, path_traversal, command_injection, honeypot } }
const lbState = {};
INIT_LEADERBOARD.forEach(row => {
    lbState[row.nickname] = {
        total:             parseInt(row.total)             || 0,
        sqli:              parseInt(row.sqli)              || 0,
        xss:               parseInt(row.xss)               || 0,
        path_traversal:    parseInt(row.path_traversal)    || 0,
        command_injection: parseInt(row.command_injection) || 0,
        honeypot:          parseInt(row.honeypot)          || 0,
    };
});

// Nickname yang sudah terlihat (untuk hitung unique_users client-side)
const seenNicks = new Set(INIT_LEADERBOARD.map(r => r.nickname));

// ── Helpers ───────────────────────────────────────────────────────────────────

function layerMeta(layer) {
    if (layer === 'app-waf')          return { badgeClass: 'badge-waf',      cardClass: 'card-waf',      textClass: 'text-waf',      label: 'APP · WAF' };
    if (layer === 'honeypot')         return { badgeClass: 'badge-honeypot', cardClass: 'card-honeypot', textClass: 'text-honeypot', label: 'HONEYPOT' };
    if (layer === 'network-suricata') return { badgeClass: 'badge-suricata', cardClass: 'card-suricata', textClass: 'text-suricata', label: 'SURICATA' };
    return                                   { badgeClass: 'badge-unknown',  cardClass: 'card-unknown',  textClass: 'text-gray-400', label: layer || '?' };
}

function attackLabel(type) {
    const map = {
        sqli:              'SQL Injection',
        xss:               'Cross-Site Scripting (XSS)',
        path_traversal:    'Path Traversal',
        command_injection: 'Command Injection',
        honeypot_access:   'Honeypot Access',
    };
    return map[type] || type || '?';
}

function sevColor(sev) {
    const map = { critical: 'text-red-400', high: 'text-orange-400', medium: 'text-yellow-400', low: 'text-blue-400' };
    return map[sev] || 'text-gray-400';
}

function fmtTime(ts) {
    const d = ts ? new Date(ts) : new Date();
    return d.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
}

function escHtml(s) {
    return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// ── Render sebuah event card ──────────────────────────────────────────────────

function buildEventCard(ev, animate) {
    const m = layerMeta(ev.layer);
    const isHoneypot = ev.layer === 'honeypot';
    const payload = escHtml((ev.payload || '').substring(0, 120));

    const card = document.createElement('div');
    card.className = `bg-white/[0.03] border rounded-2xl p-4 ${m.cardClass} ${animate ? 'event-new' : ''} ${isHoneypot ? 'honeypot-glow' : ''}`;
    card.innerHTML = `
        <div class="flex items-start justify-between gap-3 mb-2">
            <div class="flex items-center gap-2 flex-wrap">
                <!-- Layer badge -->
                <span class="text-[10px] font-black tracking-widest px-2.5 py-0.5 rounded-full ${m.badgeClass}">${m.label}</span>
                <!-- Attack type -->
                <span class="text-base font-bold ${m.textClass}">${attackLabel(ev.attack_type)}</span>
                ${isHoneypot ? '<span class="text-[10px] font-bold text-red-400 bg-red-950/50 border border-red-800/40 rounded-full px-2 py-0.5">0 FALSE POSITIVE</span>' : ''}
            </div>
            <div class="flex items-center gap-2 shrink-0">
                <span class="text-[10px] font-semibold ${sevColor(ev.severity)} uppercase">${ev.severity || 'medium'}</span>
                <span class="text-[10px] text-gray-600 mono">${fmtTime(ev.ts)}</span>
            </div>
        </div>

        <div class="flex items-center gap-3 mb-2 text-xs">
            <span class="text-gray-400">👤 <strong class="text-white">${escHtml(ev.nickname || 'anonymous')}</strong></span>
            <span class="text-gray-600">|</span>
            <span class="text-gray-400 mono">${escHtml(ev.method || '')} ${escHtml(ev.route || '')}</span>
            <span class="text-gray-600">|</span>
            <span class="text-gray-500 mono text-[10px]">${escHtml(ev.src_ip || '')}</span>
        </div>

        ${payload ? `
        <div class="bg-black/40 rounded-xl px-3 py-2 mono text-xs ${m.textClass} truncate" title="${payload}">
            ${payload}
        </div>` : ''}
    `;
    return card;
}

// ── Feed management ───────────────────────────────────────────────────────────

const feedEl      = document.getElementById('feed');
const feedCountEl = document.getElementById('feed-count');
const MAX_FEED    = 40;
let feedCount     = 0;

function prependToFeed(ev, animate) {
    const card = buildEventCard(ev, animate);
    const emptyMsg = feedEl.querySelector('.text-center');
    if (emptyMsg) emptyMsg.remove();

    feedEl.insertBefore(card, feedEl.firstChild);
    feedCount++;
    feedCountEl.textContent = feedCount + ' events';

    // Trim: jaga feed tidak lebih dari MAX_FEED item
    while (feedEl.children.length > MAX_FEED) {
        feedEl.removeChild(feedEl.lastChild);
    }

    // Scroll ke atas kalau posisi sudah di atas
    if (feedEl.scrollTop < 100) feedEl.scrollTop = 0;
}

// ── Leaderboard rendering ─────────────────────────────────────────────────────

const lbBodyEl = document.getElementById('leaderboard-body');

function renderLeaderboard() {
    const sorted = Object.entries(lbState)
        .map(([nick, d]) => ({ nick, ...d }))
        .sort((a, b) => b.total - a.total)
        .slice(0, 15);

    const typeColors = {
        sqli: 'bg-orange-900/60 text-orange-300',
        xss: 'bg-purple-900/60 text-purple-300',
        path_traversal: 'bg-yellow-900/60 text-yellow-300',
        command_injection: 'bg-green-900/60 text-green-300',
        honeypot: 'bg-red-900/60 text-red-300',
    };

    lbBodyEl.innerHTML = sorted.map((entry, i) => {
        const rank = i + 1;
        const rankClass = rank === 1 ? 'rank-1' : rank === 2 ? 'rank-2' : rank === 3 ? 'rank-3' : 'text-gray-600';
        const rankIcon = rank === 1 ? '🥇' : rank === 2 ? '🥈' : rank === 3 ? '🥉' : rank;

        // Badge per attack type (hanya yang > 0)
        const badges = Object.entries(typeColors)
            .filter(([key]) => (entry[key] || 0) > 0)
            .map(([key, cls]) => {
                const shortLabel = { sqli:'SQL', xss:'XSS', path_traversal:'PATH', command_injection:'CMD', honeypot:'🪤' };
                return `<span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full ${cls}">${shortLabel[key]} ${entry[key]}</span>`;
            }).join('');

        return `<div class="bg-white/[0.03] border border-white/5 rounded-2xl px-4 py-3">
            <div class="flex items-center justify-between mb-1.5">
                <div class="flex items-center gap-2">
                    <span class="text-lg font-black ${rankClass} w-7 text-center leading-none">${rankIcon}</span>
                    <span class="text-base font-bold text-white truncate max-w-[120px]">${escHtml(entry.nick)}</span>
                </div>
                <span class="text-2xl font-black ${rankClass}">${entry.total}</span>
            </div>
            ${badges ? `<div class="flex flex-wrap gap-1 ml-9">${badges}</div>` : ''}
        </div>`;
    }).join('');

    if (sorted.length === 0) {
        lbBodyEl.innerHTML = '<p class="text-center text-gray-700 text-sm mt-8">Belum ada peserta.</p>';
    }
}

// ── Stat counter update ───────────────────────────────────────────────────────

function updateStats(ev) {
    statState.total++;
    if (!seenNicks.has(ev.nickname)) {
        seenNicks.add(ev.nickname);
        statState.unique_users++;
    }
    if (ev.attack_type === 'sqli')              statState.sqli++;
    if (ev.attack_type === 'xss')               statState.xss++;
    if (ev.attack_type === 'path_traversal')    statState.path_traversal++;
    if (ev.attack_type === 'command_injection') statState.command_injection++;
    if (ev.layer === 'honeypot')                statState.honeypot++;
    if (ev.layer === 'network-suricata')        statState.suricata++;

    document.getElementById('stat-total').textContent    = statState.total;
    document.getElementById('stat-users').textContent    = statState.unique_users;
    document.getElementById('stat-sqli').textContent     = statState.sqli;
    document.getElementById('stat-xss').textContent      = statState.xss;
    document.getElementById('stat-path').textContent     = statState.path_traversal;
    document.getElementById('stat-cmd').textContent      = statState.command_injection;
    document.getElementById('stat-honey').textContent    = statState.honeypot;
    document.getElementById('stat-suricata').textContent = statState.suricata;
}

// ── Leaderboard state update ──────────────────────────────────────────────────

function updateLeaderboard(ev) {
    const nick = ev.nickname || 'anonymous';
    if (!lbState[nick]) {
        lbState[nick] = { total:0, sqli:0, xss:0, path_traversal:0, command_injection:0, honeypot:0 };
    }
    lbState[nick].total++;
    if (ev.attack_type in lbState[nick]) lbState[nick][ev.attack_type]++;
    renderLeaderboard();
}

// ── Socket.io ─────────────────────────────────────────────────────────────────

const socket = io();
socket.emit('join-monitor'); // masuk ke room monitor

socket.on('new-event', (ev) => {
    prependToFeed(ev, true); // true = animasi slide-in
    updateStats(ev);
    updateLeaderboard(ev);
});

socket.on('connect',    () => console.log('[Monitor] Socket connected'));
socket.on('disconnect', () => console.log('[Monitor] Socket disconnected'));

// Server broadcast 'reset' → wipe semua state di semua tab monitor serentak
socket.on('reset', () => resetClientState());

// ── Reset client state ────────────────────────────────────────────────────────

function resetClientState() {
    // Bersihkan feed
    feedEl.innerHTML = `
        <div class="text-center text-gray-700 text-sm mt-16">
            <p class="text-4xl mb-3">🛡</p>
            <p>Data direset. Menunggu serangan pertama…</p>
        </div>`;
    feedCount = 0;
    feedCountEl.textContent = '0 events';

    // Reset counters
    statState = { total:0, unique_users:0, sqli:0, xss:0,
                  path_traversal:0, command_injection:0, honeypot:0, suricata:0 };
    document.getElementById('stat-total').textContent    = 0;
    document.getElementById('stat-users').textContent    = 0;
    document.getElementById('stat-sqli').textContent     = 0;
    document.getElementById('stat-xss').textContent      = 0;
    document.getElementById('stat-path').textContent     = 0;
    document.getElementById('stat-cmd').textContent      = 0;
    document.getElementById('stat-honey').textContent    = 0;
    document.getElementById('stat-suricata').textContent = 0;

    // Reset leaderboard
    Object.keys(lbState).forEach(k => delete lbState[k]);
    seenNicks.clear();
    renderLeaderboard();
}

// ── Modal reset ───────────────────────────────────────────────────────────────

function confirmReset() {
    document.getElementById('reset-modal').classList.remove('hidden');
}
function closeResetModal() {
    document.getElementById('reset-modal').classList.add('hidden');
}

async function doReset() {
    const btn = document.querySelector('#reset-modal button:last-child');
    btn.textContent = 'Mereset…';
    btn.disabled    = true;

    try {
        const res  = await fetch('/api/reset?token=<%= token %>', { method: 'POST' });
        const data = await res.json();
        if (!data.ok) throw new Error(data.error || 'Gagal');
        // socket.on('reset') sudah menangani wipe state — tinggal tutup modal
        closeResetModal();
    } catch (err) {
        alert('Reset gagal: ' + err.message);
        btn.textContent = 'Ya, Reset';
        btn.disabled    = false;
    }
}

// Tutup modal kalau klik di luar area card
document.getElementById('reset-modal').addEventListener('click', function(e) {
    if (e.target === this) closeResetModal();
});

// ── Render initial state ──────────────────────────────────────────────────────

// Events dari server sudah dalam urutan DESC (terbaru pertama).
// Kita balik supaya saat di-prepend satu per satu, urutan akhirnya terbaru di atas.
[...INIT_EVENTS].reverse().forEach(ev => prependToFeed(ev, false));
renderLeaderboard();

</script>
</body>
</html>
