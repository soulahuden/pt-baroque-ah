<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
    body { font-family: 'Inter', sans-serif; }

    /* Background image full-screen cover */
    .bg-img {
        position: absolute; top: 0; left: 0;
        width: 100%; height: 100%;
        object-fit: cover; object-position: center;
        z-index: 0;
    }

    /* Gradient fallback — tampil kalau bg.png belum ada */
    .hero-gradient {
        background: linear-gradient(135deg, #1a0535 0%, #2d1060 50%, #1a0535 100%);
    }

    /* Overlay ungu gelap matching warna bg.png — fade dari kiri ke transparan */
    .hero-overlay {
        position: absolute; inset: 0;
        background: linear-gradient(
            to right,
            rgba(12, 4, 30, 0.88) 0%,
            rgba(12, 4, 30, 0.60) 30%,
            rgba(12, 4, 30, 0.15) 55%,
            rgba(12, 4, 30, 0)    72%
        );
        z-index: 1;
    }

    /* Glassmorphism shorthand */
    .glass {
        background: rgba(255,255,255,0.65);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255,255,255,0.4);
    }
    .glass-dark {
        background: rgba(0,0,0,0.55);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255,255,255,0.1);
    }
</style>
