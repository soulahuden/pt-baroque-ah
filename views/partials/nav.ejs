<%
  var _cur = locals.current || '';
  function navClass(page) {
      return _cur === page
          ? 'px-5 py-2 bg-black text-white rounded-full text-sm font-medium'
          : 'px-5 py-2 hover:bg-black/10 text-gray-700 rounded-full text-sm font-medium transition';
  }
%>
<nav class="relative z-20 flex justify-between items-center px-10 py-7">
    <a href="/" class="flex items-center gap-2 group">
        <div class="w-8 h-8 rounded-full border-2 border-white/70 flex items-center justify-center shadow-sm group-hover:bg-white/20 transition">
            <div class="w-3 h-3 bg-white rotate-45 transition"></div>
        </div>
    </a>

    <div class="flex items-center bg-white/70 backdrop-blur-md rounded-full px-1 py-1 border border-gray-200 shadow-sm">
        <a href="/"        class="<%= navClass('home') %>">Home</a>
        <a href="/comments" class="<%= navClass('comments') %>">Komentar</a>
        <a href="/search"   class="<%= navClass('search') %>">Search</a>
        <a href="/tools"    class="<%= navClass('tools') %>">Tools</a>
    </div>

    <div class="flex items-center gap-4">
        <a href="/play"    class="text-sm font-medium text-white/75 hover:text-white transition">Cara Main</a>
        <a href="/monitor" class="bg-black text-white px-6 py-2.5 rounded-full text-sm font-semibold hover:bg-gray-800 transition shadow-md">
            Monitor
        </a>
    </div>
</nav>
